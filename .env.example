# Database (Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis (Railway)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=supersecretaccesskey12345678901234
JWT_REFRESH_SECRET=supersecretrefreshkey12345678901234
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AI
GROQ_API_KEY=your_groq_api_key

# URLs
FRONTEND_URL=https://your-client.up.railway.app
VITE_API_URL=https://your-server.up.railway.app/api
VITE_SOCKET_URL=https://your-server.up.railway.app