{
  "compilerOptions": {
    "target":           "ESNext",
    "module":           "ESNext",
    "moduleResolution": "Bundler",
    "rootDir":          "./src",
    "outDir":           "./dist",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "sourceMap":        true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}